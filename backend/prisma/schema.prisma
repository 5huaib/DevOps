generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password_hash String
  createdAt     DateTime  @default(now())
  projects      Project[]
}

model Project {
  id           String     @id @default(uuid())
  name         String
  repoUrl      String?
  type         String     @default("pipeline") // pipeline, freestyle, folder
  script       String?
  parentId     String?
  parent       Project?   @relation("ProjectToFolder", fields: [parentId], references: [id])
  children     Project[]  @relation("ProjectToFolder")
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
  pipelines    Pipeline[]
}

model Pipeline {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  status      String    @default("pending") // pending, running, success, failed
  triggerType String    @default("manual") // manual, webhook
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  jobs        Job[]
}

model Job {
  id          String   @id @default(uuid())
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id])
  stageName   String   // build, test, deploy
  status      String   @default("pending") // pending, running, success, failed
  logs        String?  
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  endedAt     DateTime?
}
